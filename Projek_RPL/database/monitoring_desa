CREATE TABLE dokumentasi (
    id_dokumentasi INT AUTO_INCREMENT PRIMARY KEY,
    id_proyek INT,
    foto VARCHAR(255),
    tanggal_upload DATE,
    keterangan TEXT,
    FOREIGN KEY(id_proyek)
    REFERENCES proyek(id_proyek)
    ON DELETE CASCADE
);

CREATE TABLE pengumuman (
    id_pengumuman INT AUTO_INCREMENT PRIMARY KEY,
    judul VARCHAR(200),
    isi TEXT,
    tanggal DATE
);

CREATE TABLE profil_desa (
    id_profil INT AUTO_INCREMENT PRIMARY KEY,
    nama_desa VARCHAR(150),
    alamat TEXT,
    visi TEXT,
    misi TEXT,
    sejarah TEXT,
    foto VARCHAR(255)
);

CREATE TABLE kontak_desa (
    id_kontak INT AUTO_INCREMENT PRIMARY KEY,
    telepon VARCHAR(20),
    email VARCHAR(100),
    website VARCHAR(100)
);