CREATE TABLE anggaran (
    id_anggaran INT AUTO_INCREMENT PRIMARY KEY,
    id_proyek INT,
    alokasi BIGINT,
    realisasi BIGINT,
    FOREIGN KEY(id_proyek)
    REFERENCES proyek(id_proyek)
    ON DELETE CASCADE
);

