CREATE DATABASE IF NOT EXISTS monitoring_desa;
USE monitoring_desa;

CREATE TABLE user (
    id_user INT AUTO_INCREMENT PRIMARY KEY,
    username VARCHAR(50) NOT NULL,
    password VARCHAR(100) NOT NULL,
    nama_lengkap VARCHAR(100),
    role VARCHAR(20)
);

