CREATE TABLE progress_fisik (
    id_progress INT AUTO_INCREMENT PRIMARY KEY,
    id_proyek INT,
    persentase INT,
    tanggal_update DATE,
    keterangan TEXT,
    FOREIGN KEY(id_proyek)
    REFERENCES proyek(id_proyek)
    ON DELETE CASCADE
);

