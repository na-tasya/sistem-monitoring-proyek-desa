CREATE TABLE proyek (
    id_proyek INT AUTO_INCREMENT PRIMARY KEY,
    nama_proyek VARCHAR(200),
    lokasi VARCHAR(200),
    deskripsi TEXT,
    tanggal_mulai DATE,
    tanggal_selesai DATE,
    status_proyek ENUM(
        'Perencanaan',
        'Berjalan',
        'Selesai'
    ) DEFAULT 'Perencanaan'
);

